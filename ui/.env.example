# OPCIONAL. Base origin do stack (sem trailing slash). Quando setado, o app deriva:
#   - REST API:                       {VITE_BASE_URL}/api
#   - Ghost auth (token/portal/JWKS): {VITE_BASE_URL}
#
# Default = "" (same-origin): a UI faz fetch para /api/* e /members/*, e o reverse proxy
# (Caddy em prod/dev, ou vite.config server.proxy em `npm run dev` standalone) roteia.
#
# Setar APENAS quando UI estiver hospedada em origin diferente da API/Ghost
# (ex: app.example.com -> api.example.com). Nesse caso CORS precisa estar liberado.
VITE_BASE_URL=

# CORS: The Ghost server MUST allow credentialed requests from your app origin.
# It cannot use Access-Control-Allow-Origin: * when credentials are used.
# Configure the Ghost host/proxy to respond with:
#   Access-Control-Allow-Origin: <your app origin, e.g. http://localhost:8080, http://localhost (Caddy + /app/), or https://app.example.com>
#   Access-Control-Allow-Credentials: true
# for the path /members/api/session (and optionally /members/.well-known/jwks.json).

# Ghost JWKS JSON string (optional). From {VITE_BASE_URL}/members/.well-known/jwks.json
# If omitted, token is still stored and sent; verification can be done on the backend.
# VITE_GHOST_JWKS=
