#
# Configurações utilizadas pelo sistema de autenticação via Ghost Members.
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente.
#

# URL base do site Ghost (deve terminar com "/").
GHOST_BASE_URL=https://legisla.tech/

# Endpoints padrão utilizados pelo Ghost Members. Ajuste se sua instalação
# utilizar caminhos personalizados.
GHOST_MEMBERS_API_AUDIENCE=https://legisla.tech/members/api
GHOST_MEMBERS_API_ISSUER=https://legisla.tech/members/api
GHOST_JWKS_PATH=members/.well-known/jwks.json

# Segredo configurado no webhook da integração customizada do Ghost.
# Usado para validar o header X-Ghost-Signature em /api/webhooks/ghost/members.
GHOST_WEBHOOK_SECRET=troque-este-segredo
GHOST_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Mantido para compatibilidade com implementações antigas.
PREFIX_URL=https://legisla.tech/


DATABASE_URL=postgresql://USUARIO:SENHA@URL:PORTA/BANCO
SQLALCHEMY_ECHO=0
APPLICATION_NAME=ALIAS

# Política de visibilidade do catálogo autenticado de parlamentares. É lida
# em runtime pela API: current_only (padrão seguro), current_and_licensed ou
# all_ingested. A UI consulta /api/parliamentarians/catalog-config; não use
# VITE_* para esta política.
MAMUTE_PARLIAMENTARIAN_CATALOG_SCOPE=current_only

# Overrides operacionais de limites por slug do tier Ghost.
# Se ausente, o limite de parlamentares monitorados vem de projetos.qtd_termos.
MAMUTE_TIER_LIMITS_JSON={"free":{"qtd_termos":1,"qtd_consultas_ia_mes":0},"default-product":{"qtd_termos":3,"qtd_consultas_ia_mes":50},"cidadao-mamute":{"qtd_termos":10,"qtd_consultas_ia_mes":200}}
