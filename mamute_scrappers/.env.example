DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mamute
SQLALCHEMY_ECHO=1
APPLICATION_NAME=MAMUTE_POLITICO_CRAWLER

# Escopo da sincronização diária de deputados da Câmara. O padrão seguro é
# current_only (apenas em exercício). current_and_licensed inclui licenciados
# da legislatura vigente; current_legislature mantém todos os registros dela.
MAMUTE_CAMARA_INGEST_SCOPE=current_only

GHOST_API_KEY=
GHOST_ADMIN_URL=

# E-mail — relatórios (scripts/notificacao). Todos os provedores são SMTP.
# MAIL_PROVIDER seleciona o conjunto de credenciais: "mailgun" ou "ses".
# Qualquer valor ausente no conjunto do provedor cai no legado SMTP_* abaixo.
MAIL_PROVIDER=mailgun

# Remetente comum (vale para os dois provedores; pode ter override por prefixo)
SMTP_SENDER=relatorios@mamutepolitico.com.br
SMTP_FROM_NAME=Mamute Político

# Mailgun (entrega a usuários reais; mesma conta do Ghost)
MAILGUN_SMTP_SERVER=smtp.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_USER=
MAILGUN_SMTP_PASSWD=

# Amazon SES (mantido; hoje em sandbox — só entrega a identidades verificadas)
SES_SMTP_SERVER=email-smtp.sa-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASSWD=

# Legado (retrocompat): usado quando MAIL_PROVIDER está vazio
SMTP_USER=
SMTP_PASSWD=
SMTP_SERVER=
SMTP_PORT=587

# Branding dos e-mails (opcional — ver mamute_scrappers/scripts/notificacao/README.md)
MAMUTE_APP_URL=https://mamutepolitico.com.br
MAMUTE_EMAIL_LOGO_URL=https://mamutepolitico.com.br/app/assets/logo-mamute-Cn9vnXen.png
MAMUTE_EMAIL_MANAGE_URL=https://mamutepolitico.com.br/app
MAMUTE_PRIVACY_URL=https://mamutepolitico.com.br/privacidade
