# Copie este arquivo para ".env" e preencha os valores conforme sua infraestrutura.

APP_ENV=local
APPLICATION_NAME=mamute_chatbot_backend

OPENAI_API_KEY=coloque_sua_chave_aqui
# Para OpenRouter ou outro endpoint OpenAI-compatible:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1024
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# Conexões com PostgreSQL
DATABASE_URL=postgresql+psycopg://usuario:senha@localhost:5432/mamute
PGVECTOR_CONNECTION=postgresql+psycopg://usuario:senha@localhost:5432/mamute
PGVECTOR_COLLECTION=mamute_chatbot_transcripts

# Autenticação Ghost Members exigida pelas rotas /chatbot/query e /chatbot/stream
GHOST_BASE_URL=http://localhost:2368
# GHOST_MEMBERS_API_AUDIENCE=http://localhost:2368/members/api
# GHOST_MEMBERS_API_ISSUER=http://localhost:2368/members/api
# GHOST_JWKS_PATH=members/.well-known/jwks.json

# Quota mensal de consultas IA por tier Ghost (slug); não desliga autenticação
MAMUTE_CHATBOT_QUOTA_ENABLED=false
MAMUTE_CHATBOT_DEFAULT_MONTHLY_LIMIT=0
MAMUTE_TIER_LIMITS_JSON={"free":{"qtd_termos":1,"qtd_consultas_ia_mes":0},"default-product":{"qtd_termos":3,"qtd_consultas_ia_mes":50},"cidadao-mamute":{"qtd_termos":10,"qtd_consultas_ia_mes":200}}
# Override opcional só para o chatbot; se definido, ganha de MAMUTE_TIER_LIMITS_JSON.
MAMUTE_CHATBOT_MONTHLY_LIMITS_JSON=
MAMUTE_CHATBOT_QUOTA_FAIL_OPEN=false

# Ajustes do retriever e reranking
RETRIEVER_K=6
RETRIEVER_SCORE_THRESHOLD=0.35
RERANK_TOP_K=5

# Ajustes das consultas SQL auxiliares
SQL_CONTEXT_LIMIT=5
SQL_MIN_KEYWORD_LENGTH=4
SQL_FREQUENCY_LIMIT=5
SQL_KEYWORDS_LIMIT=8
SQL_ENTITIES_LIMIT=6
SQL_PROPOSITIONS_LIMIT=6

# Observabilidade
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=mamute-chatbot
